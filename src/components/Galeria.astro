---
interface GalleryImage {
  src: string;
  alt?: string;
}

interface Props {
  images: GalleryImage[];
  title?: string;
}

const { images, title = "Nuestros momentos" } = Astro.props;
const serializedImages = JSON.stringify(images);
---

<section class="section gallery-section" data-gallery data-images={serializedImages}>
  <p class="section-script">Nuestra galeria</p>
  <h2 class="section-title section-title--small">{title}</h2>
  <p class="body-copy gallery-copy">
    Un vistazo a los recuerdos que nos trajeron hasta este gran dia.
  </p>

  <div class="gallery-grid">
    {
      images.map((image, index) => (
        <button
          class="gallery-thumb"
          type="button"
          data-gallery-thumb
          data-index={index}
          aria-label={`Abrir imagen ${index + 1}`}
        >
          <img src={image.src} alt={image.alt ?? `Recuerdo ${index + 1}`} loading="lazy" decoding="async" />
        </button>
      ))
    }
  </div>

  <div class="gallery-modal" data-gallery-modal aria-hidden="true">
    <button class="gallery-modal__backdrop" type="button" data-gallery-close aria-label="Cerrar galeria"></button>
    <div class="gallery-modal__dialog" role="dialog" aria-modal="true" aria-label="Galeria de fotos">
      <button class="gallery-modal__close" type="button" data-gallery-close aria-label="Cerrar galeria">
        ×
      </button>
      <img class="gallery-modal__image" data-gallery-image alt="" />
      <div class="gallery-modal__actions">
        <button class="button-secondary" type="button" data-gallery-prev>
          Anterior
        </button>
        <button class="button-secondary" type="button" data-gallery-next>
          Siguiente
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-gallery]").forEach((section) => {
    const element = section;
    const images = JSON.parse(element.getAttribute("data-images") || "[]");
    const modal = element.querySelector("[data-gallery-modal]");
    const modalImage = element.querySelector("[data-gallery-image]");
    const thumbs = Array.from(element.querySelectorAll("[data-gallery-thumb]"));
    const closeButtons = element.querySelectorAll("[data-gallery-close]");
    const prevButton = element.querySelector("[data-gallery-prev]");
    const nextButton = element.querySelector("[data-gallery-next]");

    if (!modal || !modalImage || !prevButton || !nextButton || !images.length) return;

    let currentIndex = 0;

    const renderImage = () => {
      const currentImage = images[currentIndex];
      if (!currentImage) return;

      modalImage.setAttribute("src", currentImage.src);
      modalImage.setAttribute("alt", currentImage.alt || `Recuerdo ${currentIndex + 1}`);
    };

    const openModal = (index) => {
      currentIndex = index;
      renderImage();
      modal.classList.add("is-active");
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("is-gallery-open");
    };

    const closeModal = () => {
      modal.classList.remove("is-active");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("is-gallery-open");
    };

    const move = (direction) => {
      currentIndex = (currentIndex + direction + images.length) % images.length;
      renderImage();
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const nextIndex = Number(thumb.getAttribute("data-index") || "0");
        openModal(nextIndex);
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", closeModal);
    });

    prevButton.addEventListener("click", () => move(-1));
    nextButton.addEventListener("click", () => move(1));

    document.addEventListener("keydown", (event) => {
      if (!modal.classList.contains("is-active")) return;

      if (event.key === "Escape") closeModal();
      if (event.key === "ArrowLeft") move(-1);
      if (event.key === "ArrowRight") move(1);
    });
  });
</script>
