---
interface Props {
  couple: string;
  dateLabel: string;
  city: string;
  ctaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const {
  couple,
  dateLabel,
  city,
  ctaHref = "#historia",
  imageSrc,
  imageAlt = `Foto de ${couple}`,
} = Astro.props;
---

<section class="section hero-panel hero-panel--mist">
  <p class="eyebrow">Invitacion de boda</p>
  <h1 class="display-name">{couple}</h1>
  <p class="hero-copy">
    Una noche para celebrar el amor, la familia y todos los recuerdos que apenas comienzan.
  </p>

  <div class="photo-card photo-card--tall">
    {
      imageSrc ? (
        <img class="photo-media" src={imageSrc} alt={imageAlt} loading="eager" decoding="async" />
      ) : (
        <div class="photo-placeholder">
          <span>Agrega aqui su foto portada</span>
        </div>
      )
    }
  </div>

  <div class="mini-note">
    <span>{dateLabel}</span>
    <span>{city}</span>
  </div>

  <a class="button-primary" href={ctaHref}>Ver invitacion</a>
</section>
