---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Invitacion de Boda" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Invitacion digital de boda" />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("is-sealed");
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
